# === Base ===
APP_NAME=AI-Chat-Companion
APP_ENV=production
API_KEY=your-secret-api-key-change-this

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///data/chat.db

# === File Storage ===
AVATAR_MAX_SIZE=5
AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# === LLM API ===
# 请替换为你的实际 LLM API 地址和密钥
LLM_API_URL=https://api.example.com/v1/chat/completions
LLM_API_KEY=your-llm-api-key
LLM_MODEL_NAME=gpt-4o-mini
LLM_MODEL_NAME_CHEAP=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60

# === Embedding API ===
EMBEDDING_API_URL=https://api.example.com/v1/embeddings
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# === Qdrant ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=memories

# === Redis (arq workers) ===
REDIS_URL=redis://redis:6379
USE_WORKERS=true

# === Memory ===
MEMORY_TOP_K=5
MEMORY_DECAY_DAYS=30
RECENT_HISTORY_ROUNDS=10
MAX_PROMPT_TOKENS=6000

# === Logging ===
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_TO_DB=true
LOG_TO_FILE=true
LOG_FILE_PATH=data/logs/app.log

# === 搜索 API（博查 Bocha） ===
# 注册获取免费 API Key: https://open.bochaai.com
SEARCH_API_URL=https://api.bochaai.com/v1/web-search
SEARCH_API_KEY=your-bocha-api-key-here
SEARCH_RESULT_COUNT=5
SEARCH_TIMEOUT=10
